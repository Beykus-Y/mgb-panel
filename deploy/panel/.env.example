PANEL_PORT=8443
PANEL_BASE_URL=https://localhost:8443
PANEL_STATE_DIR=./state/panel
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password
TLS_MODE=internal
TLS_CERT_FILE=
TLS_KEY_FILE=
LETSENCRYPT_DIR=/etc/letsencrypt
ENABLE_LOCAL_NODE=false
LOCAL_NODE_TOKEN=
LOCAL_NODE_STATE_DIR=./state/local-node
LOCAL_NODE_POLL_INTERVAL=20s
PANEL_IMAGE=ghcr.io/beykus-y/mgb-panel:panel-latest
NODE_IMAGE=ghcr.io/beykus-y/mgb-panel:node-latest
